#!/bin/sh

find_conf() {
	if [ -n "${TAILSCALE_ENABLER_CONF:-}" ]; then
		echo "$TAILSCALE_ENABLER_CONF"
	elif [ -f /etc/tailscale-enabler.conf ]; then
		echo /etc/tailscale-enabler.conf
	elif [ -f /etc/storage/tailscale-enabler.conf ]; then
		echo /etc/storage/tailscale-enabler.conf
	elif [ -f /mnt/tailscale-enabler.conf ]; then
		echo /mnt/tailscale-enabler.conf
	else
		echo /overlay/tailscale-enabler.conf
	fi
}

CONF=`find_conf`
[ -f "$CONF" ] && . "$CONF"

DIR=${TAILSCALE_DIR:-/tmp/tailscale}
STATE_DIR=${TAILSCALE_STATE_DIR:-/overlay/tailscale-state}
STATE_FILE=${TAILSCALE_STATE_FILE:-$STATE_DIR/tailscaled.state}
# Socket and pidfile default under $DIR: guaranteed writable, RAM-backed
# on these routers, and gone after reboot like runtime files must be.
RUNTIME_DIR=${TAILSCALE_RUNTIME_DIR:-$DIR/run}
SOCKET=${TAILSCALE_SOCKET:-$RUNTIME_DIR/tailscaled.sock}
PIDFILE=${TAILSCALE_PIDFILE:-$RUNTIME_DIR/tailscaled.pid}
LOGFILE=${TAILSCALE_LOGFILE:-$DIR/tailscaled.log}
TUN=${TAILSCALE_TUN:-tailscale0}
PORT=${TAILSCALE_PORT:-41641}
ENABLE_FORWARDING=${TAILSCALE_ENABLE_FORWARDING:-1}
PROC_MISC=${TAILSCALE_PROC_MISC:-/proc/misc}

# Applets from the BusyBox the installer downloads for 1.13-era firmwares
# that miss mv or mknod.
if [ -d "$DIR/bb" ]; then
	PATH="$DIR/bb:$PATH"
	export PATH
fi

# Some ancient BusyBox ash builds (1.8-era and older) lack the `command`
# builtin, so probing tools with it aborts the whole script there. Only
# external tools are ever probed, so scanning PATH by hand is enough.
have() {
	_HAVE_IFS=$IFS
	IFS=:
	for _HAVE_DIR in $PATH; do
		if [ -x "${_HAVE_DIR:-.}/$1" ]; then
			IFS=$_HAVE_IFS
			return 0
		fi
	done
	IFS=$_HAVE_IFS
	return 1
}

mv_file() {
	if have mv; then
		mv "$1" "$2"
	else
		cat "$1" > "$2" && rm -f "$1"
	fi
}

ensure_dirs() {
	mkdir -p "$DIR" "$STATE_DIR" "$RUNTIME_DIR"
}

tun_available() {
	modprobe tun 2>/dev/null || insmod tun 2>/dev/null || true

	if [ ! -e /dev/net/tun ]; then
		mkdir -p /dev/net 2>/dev/null || true
		mknod /dev/net/tun c 10 200 2>/dev/null || true
		chmod 600 /dev/net/tun 2>/dev/null || true
	fi

	[ -c /dev/net/tun ] || return 1
	grep -qw tun "$PROC_MISC" 2>/dev/null
}

fallback_to_userspace() {
	echo "TUN device is unavailable; falling back to userspace-networking" >&2
	echo "exit node and subnet routing are disabled on this device" >&2
	TUN=userspace-networking

	[ -f "$CONF" ] || return 0
	if grep -q "^TAILSCALE_TUN=" "$CONF"; then
		sed "s|^TAILSCALE_TUN=.*|TAILSCALE_TUN='userspace-networking'|" \
			"$CONF" > "$CONF.tmp.$$" && mv_file "$CONF.tmp.$$" "$CONF"
	else
		echo "TAILSCALE_TUN='userspace-networking'" >> "$CONF"
	fi
	echo "updated $CONF; on Padavan run 'mtd_storage.sh save' to persist it" >&2
}

prepare_routing() {
	[ "$TUN" = "userspace-networking" ] && return 0

	if ! tun_available; then
		fallback_to_userspace
		return 0
	fi

	[ "$ENABLE_FORWARDING" = "1" ] || return 0
	echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || true
	for file in /proc/sys/net/ipv4/conf/*/rp_filter; do
		[ -e "$file" ] && echo 0 > "$file" 2>/dev/null
	done
	[ -e /proc/sys/net/ipv6/conf/all/forwarding ] && \
		echo 1 > /proc/sys/net/ipv6/conf/all/forwarding 2>/dev/null
}

is_running() {
	[ -f "$PIDFILE" ] || return 1
	pid=`cat "$PIDFILE" 2>/dev/null`
	[ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

start() {
	ensure_dirs
	prepare_routing

	if is_running; then
		echo "tailscaled already running"
		return 0
	fi

	if [ ! -x "$DIR/tailscaled" ]; then
		echo "tailscaled not found: $DIR/tailscaled" >&2
		return 1
	fi

	rm -f "$SOCKET"
	"$DIR/tailscaled" \
		--state="$STATE_FILE" \
		--statedir="$STATE_DIR" \
		--socket="$SOCKET" \
		--tun="$TUN" \
		--port="$PORT" \
		--no-logs-no-support \
		>"$LOGFILE" 2>&1 &
	pid=$!
	echo "$pid" > "$PIDFILE"

	sleep 2
	if ! kill -0 "$pid" 2>/dev/null; then
		echo "tailscaled exited right after start; last log lines:" >&2
		tail -n 20 "$LOGFILE" >&2 2>/dev/null
		rm -f "$PIDFILE"
		return 1
	fi
	echo "tailscaled started (pid $pid)"
}

stop() {
	if is_running; then
		pid=`cat "$PIDFILE"`
		kill "$pid" 2>/dev/null || true
		# Give it ten seconds, counted with a string so ash builds without
		# arithmetic expansion or expr can run this too.
		waited=
		while [ "$waited" != ".........." ] && kill -0 "$pid" 2>/dev/null; do
			sleep 1
			waited="$waited."
		done
		if kill -0 "$pid" 2>/dev/null; then
			kill -9 "$pid" 2>/dev/null || true
		fi
	fi
	rm -f "$PIDFILE" "$SOCKET"
	echo "tailscaled stopped"
}

status() {
	if is_running; then
		echo "tailscaled running (pid `cat "$PIDFILE"`)"
		return 0
	fi
	echo "tailscaled not running"
	return 1
}

case "${1:-start}" in
	start) start ;;
	stop) stop ;;
	restart) stop; start ;;
	status) status ;;
	*)
		echo "usage: $0 {start|stop|restart|status}" >&2
		exit 2
		;;
esac
